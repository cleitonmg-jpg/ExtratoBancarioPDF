# Server
PORT=5000
HOST=127.0.0.1

# OpenAI (use one of the pairs below)
# Replit:
# AI_INTEGRATIONS_OPENAI_API_KEY=...
# AI_INTEGRATIONS_OPENAI_BASE_URL=...
#
# Local:
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=...

# ──────────────────────────────────────────────
# Banco de dados  →  escolha UMA das opções:
#
#  memory   = sem banco (dados perdidos ao reiniciar)
#  postgres = PostgreSQL local
# ──────────────────────────────────────────────
DB_TYPE=memory
# DB_TYPE=postgres

# Necessário apenas quando DB_TYPE=postgres
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/extratoai

# Sessions (optional)
SESSION_SECRET=change-me

